# Copia este archivo a `.env` y rellena los valores.

# API-Football (api-sports.io / RapidAPI). Si está vacío o es placeholder, se usa TheSportsDB.
API_FOOTBALL_KEY=tu_api_key_aqui
APIFOOTBALL_BASE_URL=https://v3.football.api-sports.io

# TheSportsDB: la clave pública de prueba suele ser 3.
THESPORTSDB_API_KEY=3

# Opcional: forzar proveedor (`api_football` | `thesportsdb`). Vacío = auto (API-Football si hay clave válida).
# DATA_PROVIDER=thesportsdb
